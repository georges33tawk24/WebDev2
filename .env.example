# =============================================================================
# WebDev2 — team local environment
# =============================================================================
#   cp .env.example .env
#   # Paste shared team secrets from team.env (ask Georges / course Discord)
#   #   cat team.env >> .env   OR copy values manually
#   composer install
#   php artisan migrate --seed
#   npm install && npm run build
#   php artisan config:clear
#
# Run the app (HTTPS required for Facebook OAuth):
#   composer dev:https
# Open: https://127.0.0.1:8000
#
# Seeded logins (password: password123):
#   admin@example.com
#   staff@example.com (+ staff.tripoli@, staff.saida@, … per office)
#   citizen@example.com (+ citizen.karim@, citizen.mira@, … — 20 citizens)
# Re-seed: php artisan migrate:fresh --seed  (wipes local DB)
# Add demo only: php artisan db:seed
# =============================================================================

APP_NAME=WebDev2
APP_ENV=local
# Shared team dev key — keep this value so sessions/encryption match for everyone
APP_KEY=base64:cxBdabsuubuUK31Ejpmou4aiQ8FeJA6q6YcXwzr8lRU=
APP_DEBUG=true
# Facebook on 127.0.0.1 requires HTTPS — use composer dev:https (brew install caddy)
APP_URL=https://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — MySQL (team default)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=webdev2
DB_USERNAME=root
DB_PASSWORD=

# SQLite quick start — comment MySQL block above and uncomment:
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail — shared team Gmail SMTP (2FA codes, password reset)
# Real values in team.env (not committed — GitHub blocks secrets in git)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Google OAuth — "Continue with Google"
# Console: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# -----------------------------------------------------------------------------
# Facebook OAuth — "Continue with Facebook"
# Meta: https://developers.facebook.com/apps/
# Valid OAuth Redirect URI: https://127.0.0.1:8000/auth/facebook/callback
# -----------------------------------------------------------------------------
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"
FACEBOOK_LOGIN_SCOPE=email,public_profile

OAUTH_VERIFY_SSL=true

# -----------------------------------------------------------------------------
# ID document OCR — https://ocr.space/ocrapi
# -----------------------------------------------------------------------------
ID_OCR_API_URL=https://api.ocr.space/parse/image
ID_OCR_API_TOKEN=
# OCR languages: eng,ara,fre,etc. (comma-separated — OCR.space)
ID_OCR_LANGUAGE=eng,ara

# Google Maps JavaScript API (citizen office map) — enable Maps JavaScript API in Google Cloud
GOOGLE_MAPS_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_DEV_SERVER_URL=http://127.0.0.1:5173
