# =============================================================================
# WebDev2 — team local environment
# =============================================================================
#   cp .env.example .env
#   # Paste shared team secrets from team.env (ask Georges / course Discord)
#   #   cat team.env >> .env   OR copy values manually
#   composer install
#   php artisan db:prepare --seed
#   npm install && npm run build
#   php artisan config:clear
#
# Run the app (HTTPS required for Facebook OAuth):
#   composer dev:https
# Open: https://127.0.0.1:8000
#
# Seeded logins (password: password123):
#   admin@example.com
#   staff@example.com (+ staff.tripoli@, staff.saida@, … per office)
#   citizen@example.com (+ citizen.karim@, citizen.mira@, … — 20 citizens)
# Re-seed: php artisan db:prepare --fresh --seed  (wipes local DB)
# Add demo only: php artisan db:seed
# SQLite quick start: set DB_CONNECTION=sqlite then db:prepare --seed
# =============================================================================

APP_NAME=WebDev2
APP_ENV=local
# Shared team dev key — keep this value so sessions/encryption match for everyone
APP_KEY=base64:cxBdabsuubuUK31Ejpmou4aiQ8FeJA6q6YcXwzr8lRU=
APP_DEBUG=true
# Facebook on 127.0.0.1 requires HTTPS — use composer dev:https (brew install caddy)
APP_URL=https://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — MySQL (team default)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=webdev2
DB_USERNAME=root
DB_PASSWORD=

# SQLite quick start — comment MySQL block above and uncomment:
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail — shared team Gmail SMTP (2FA codes, password reset)
# Real values in team.env (not committed — GitHub blocks secrets in git)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Google OAuth — "Continue with Google"
# Console: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# -----------------------------------------------------------------------------
# Facebook OAuth — "Continue with Facebook"
# Meta: https://developers.facebook.com/apps/
# Valid OAuth Redirect URI: https://127.0.0.1:8000/auth/facebook/callback
# -----------------------------------------------------------------------------
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"
FACEBOOK_LOGIN_SCOPE=email,public_profile

OAUTH_VERIFY_SSL=true

# -----------------------------------------------------------------------------
# ID document OCR — https://ocr.space/ocrapi
# -----------------------------------------------------------------------------
ID_OCR_API_URL=https://api.ocr.space/parse/image
ID_OCR_API_TOKEN=
# OCR languages: eng,ara,fre,etc. (comma-separated — OCR.space)
ID_OCR_LANGUAGE=eng,ara

# Google Maps JavaScript API (citizen office map) — enable Maps JavaScript API in Google Cloud
GOOGLE_MAPS_API_KEY=

# USD → LBP display on payments (Frankfurter API with this fallback)
EXCHANGE_USD_LBP_RATE=89500

# Stripe — real card payments in TEST mode (school project; works from Lebanon)
# Dashboard: https://dashboard.stripe.com/test/apikeys
# Test card: 4242 4242 4242 4242 · any future expiry · any CVC
STRIPE_KEY=pk_test_your_publishable_key
STRIPE_SECRET=sk_test_your_secret_key
# Optional: stripe listen --forward-to https://127.0.0.1:8000/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# NOWPayments — real crypto in SANDBOX (like Stripe test mode)
# Sandbox dashboard: https://account-sandbox.nowpayments.io/
# API key + IPN secret: Store Settings → API keys / Notifications
# Sandbox docs: use api-sandbox.nowpayments.io (NOWPAYMENTS_SANDBOX=true)
NOWPAYMENTS_API_KEY=your_sandbox_api_key
NOWPAYMENTS_IPN_SECRET=your_sandbox_ipn_secret
NOWPAYMENTS_PUBLIC_KEY=your_sandbox_public_key
NOWPAYMENTS_SANDBOX=true
# Pay currency code from NOWPayments (e.g. usdttrc20, btc, eth)
NOWPAYMENTS_PAY_CURRENCY=usdttrc20

# SMS — auto | brevo | vonage | twilio | textbee | log
# Recommended if Twilio signup fails: Brevo (https://www.brevo.com) or Vonage (https://dashboard.nexmo.com)
SMS_DRIVER=auto

# Brevo — free account, API key under SMTP & API → API keys; buy SMS credits under Channels → SMS
# Sender: alphanumeric name, max 11 chars (e.g. EServices)
BREVO_API_KEY=
BREVO_SMS_SENDER=webdev2

# Vonage — API key + secret from dashboard; "from" is sender name or virtual number
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_SMS_FROM=EServices

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Textbee — requires Android phone + SIM (https://textbee.dev/docs)
TEXTBEE_API_URL=https://api.textbee.dev
TEXTBEE_API_KEY=
TEXTBEE_DEVICE_ID=

# Browser push (Web Push / VAPID) — run: php artisan webpush:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Live updates: SSE off in local by default (blocks php artisan serve). Use php-fpm/Octane to enable locally.
# LIVE_UPDATES_SSE=false
# LIVE_UPDATES_POLL_SECONDS=5

# Appointment reminders: scheduler runs appointments:send-reminders every minute
# (include in composer dev / run: php artisan schedule:work)
APPOINTMENT_REMINDER_TOLERANCE_MINUTES=10

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_DEV_SERVER_URL=http://127.0.0.1:5173
